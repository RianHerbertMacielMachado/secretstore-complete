# ============================================================
# Environment Variables — SecretStore
# Copie para .env.local (desenvolvimento) ou configure no
# painel do Vercel em: Settings → Environment Variables
# ============================================================

# ===========================
# NEXTAUTH
# ===========================
NEXTAUTH_URL=https://seudominio.com.br
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=sua_chave_secreta_de_32_caracteres_minimo

# ===========================
# BANCO DE DADOS
# ===========================
# --- Desenvolvimento local (SQLite) ---
DATABASE_URL="file:./prisma/dev.db"

# --- Produção no Vercel (Turso) ---
# Obtenha em: https://turso.tech → seu banco → Connect
TURSO_DATABASE_URL="libsql://seu-banco-usuario.turso.io"
TURSO_AUTH_TOKEN="seu_token_turso_aqui"

# ===========================
# GOOGLE OAUTH
# ===========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================
# DISCORD OAUTH
# ===========================
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ===========================
# MERCADO PAGO (PIX)
# ===========================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ===========================
# PAYPAL
# ===========================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# ===========================
# PICPAY
# ===========================
PICPAY_TOKEN=
PICPAY_SELLER_TOKEN=

# ===========================
# GOOGLE DRIVE API (Service Account)
# ===========================
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ===========================
# EMAIL (Nodemailer)
# ===========================
# Gmail: smtp.gmail.com | Hostgator: mail.seudominio.com.br
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@seudominio.com.br

# ===========================
# CLOUDINARY (Upload de imagens)
# ===========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================
# SITE
# ===========================
NEXT_PUBLIC_SITE_URL=https://seudominio.com.br
NEXT_PUBLIC_SITE_NAME=Secret Store
