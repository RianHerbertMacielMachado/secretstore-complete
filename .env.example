# Environment Variables - DarkShop
# Copie este arquivo para .env.local e preencha com seus valores

# ===========================
# NEXTAUTH
# ===========================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=darkshop_secret_key_change_in_production_32_chars_min

# ===========================
# DATABASE (SQLite para dev)
# ===========================
DATABASE_URL="file:./dev.db"

# ===========================
# GOOGLE OAUTH
# ===========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================
# DISCORD OAUTH  
# ===========================
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ===========================
# MERCADO PAGO (PIX)
# ===========================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ===========================
# PAYPAL
# ===========================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# ===========================
# PICPAY
# ===========================
PICPAY_TOKEN=
PICPAY_SELLER_TOKEN=

# ===========================
# GOOGLE DRIVE API (Service Account)
# ===========================
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ===========================
# EMAIL (Nodemailer)
# ===========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@darkshop.com

# ===========================
# CLOUDINARY (Upload de imagens)
# ===========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================
# SITE
# ===========================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=DarkShop
