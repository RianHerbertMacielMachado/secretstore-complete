// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  role          String    @default("CUSTOMER")
  googleId      String?
  discordId     String?
  avatar        String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Hierarquia: Category → SubCategory → Product ──────────────────────────────

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  image         String?
  isVisible     Boolean       @default(true)
  sortOrder     Int           @default(0)
  subCategories SubCategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SubCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  bannerImage String?   // Imagem de fundo do banner da página de subcategoria
  isVisible   Boolean   @default(true)
  sortOrder   Int       @default(0)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                  String         @id @default(cuid())
  name                String
  slug                String         @unique
  description         String
  price               Float
  salePrice           Float?
  mainImage           String
  youtubeUrl          String?
  subCategoryId       String
  subCategory         SubCategory    @relation(fields: [subCategoryId], references: [id])
  productImages       ProductImage[]
  driveLink           String         @default("")
  driveDeliveryMethod String         @default("LINK")
  status              String         @default("ACTIVE")
  featured            Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  orderItems          OrderItem[]
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ── Orders ─────────────────────────────────────────────────────────────────────

model Order {
  id                  String      @id @default(cuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id])
  items               OrderItem[]
  totalAmount         Float
  discountAmount      Float       @default(0)
  couponCode          String?
  paymentMethod       String
  paymentStatus       String      @default("PENDING")
  paymentId           String?
  paymentConfirmedAt  DateTime?
  deliveryStatus      String      @default("PENDING")
  deliveryEmailSentAt DateTime?
  customerEmail       String      @default("")
  customerName        String      @default("")
  pixQrCodeBase64     String?     // QR Code em base64 para exibição
  pixCopiaECola       String?     // Código copia-e-cola PIX
  pixExpiresAt        DateTime?   // Expiração do PIX (30 min)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  discountType     String
  discountValue    Float
  scope            String    @default("ALL")
  categoryIds      String    @default("[]")
  productIds       String    @default("[]")
  expiresAt        DateTime?
  totalUsageLimit  Int?
  perCustomerLimit Int       @default(1)
  usageCount       Int       @default(0)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  isEncrypted Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model StoreSettings {
  id               String  @id @default(cuid())
  discordUrl       String?
  productsPerPage  Int     @default(15)
}

model WebhookLog {
  id        String   @id @default(cuid())
  provider  String
  eventType String
  payload   String
  status    String
  orderId   String?
  createdAt DateTime @default(now())
}

// ── Carrossel configurável da home ─────────────────────────────────────────────
model CarouselItem {
  id        String   @id @default(cuid())
  name      String                      // Texto exibido sobre a imagem
  image     String                      // URL da imagem de fundo
  link      String                      // URL de redirecionamento ao clicar
  sortOrder Int      @default(0)        // Ordem de exibição
  isActive  Boolean  @default(true)     // Visível no frontend
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Ticker/Faixa de avisos do topo ─────────────────────────────────────────────
model TickerItem {
  id        String   @id @default(cuid())
  text      String                      // Texto do aviso
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Configurações do ticker (global) ───────────────────────────────────────────
// Armazenado em SiteConfig com chaves: ticker_enabled, ticker_speed, ticker_color

// ── Popup de cupom ─────────────────────────────────────────────────────────────
// Armazenado em SiteConfig com chaves:
//   popup_enabled, popup_discount, popup_code, popup_expiry_hours,
//   popup_cta_text, popup_cta_link, popup_delay_seconds

